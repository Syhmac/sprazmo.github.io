<h1>Car List</h1>

<a href="/cars/create">Add new</a>

<ul class="index-list">
  <% cars.forEach(function(car) { %>
    <li>
      <h3><%= car.getManufacturer() %> <%= car.getModel() %> <%= car.getYear() %></h3>
      <ul class="action-list">
        <li><a href="/cars/<%= car.getId() %>">Details</a></li>
        <li><a href="/cars/<%= car.getId() %>/edit">Edit</a></li>
      </ul>
    </li>
  <% }); %>
</ul>
