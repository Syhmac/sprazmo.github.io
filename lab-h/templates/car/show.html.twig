{% extends 'base.html.twig' %}

{% block title %}Car{% endblock %}

{% block body %}
    <h1>Car</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ car.id }}</td>
            </tr>
            <tr>
                <th>Manufacturer</th>
                <td>{{ car.manufacturer }}</td>
            </tr>
            <tr>
                <th>Model</th>
                <td>{{ car.model }}</td>
            </tr>
            <tr>
                <th>Year</th>
                <td>{{ car.year }}</td>
            </tr>
        </tbody>
    </table>

    <div class="showButtons">
        <a href="{{ path('app_car_index') }}" class="link-btn btn-blue">Back to list</a>

        <a href="{{ path('app_car_edit', {'id': car.id}) }}" class="link-btn btn-green">Edit</a>

        {{ include('car/_delete_form.html.twig') }}
    </div>
{% endblock %}
